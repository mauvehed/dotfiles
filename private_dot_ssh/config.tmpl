########################
# HOST-SPECIFIC (from 1Password note; rendered before Host * so each host's
# own IdentityFile is offered ahead of the global default key)
########################
{{ if .personal }}
{{ onepasswordRead "op://Personal/SSH Config/notesPlain" }}
{{ else if .work }}
{{ onepasswordRead "op://Employee/SSH Config-work/notesPlain" }}
{{ end }}

########################
# GLOBAL (must be last: scalars are first-match-wins, and the global
# IdentityFile is additive — appending it last makes it the fallback)
########################
Host *
  Compression yes
  ServerAliveInterval 60
  ServerAliveCountMax 10
  IdentitiesOnly yes
  #ControlMaster auto
  #ControlPath /tmp/ssh-%r@%h:%p
  #ControlPersist yes
  {{ if eq .osid "darwin" }}
  UseKeychain yes
  # 1password ssh-agent
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
  {{ end }}
  AddKeysToAgent yes
  PreferredAuthentications publickey
  ForwardAgent no
{{ if .personal }}
  IdentityFile ~/.ssh/id_ed25519_primary
{{ else if .work }}
  IdentityFile ~/.ssh/id_ed25519
{{ end }}
