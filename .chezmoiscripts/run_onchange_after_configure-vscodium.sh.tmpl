     "monokai.theme-monokai-pro-vscode" -}}
#!/bin/bash

set -eufo pipefail

if ! command -v codium &>/dev/null; then
  echo "codium not found, skipping VSCodium configuration"
  exit 0
fi

# Install Open VSX extensions
{{ range $extensions -}}
codium --force --install-extension {{ . }}
{{ end }}
# Copy paid themes from VS Code if available
{{ range $paid_themes -}}
src_dir=$(find ~/.vscode/extensions -maxdepth 1 -name "{{ . }}-*" -type d 2>/dev/null | head -1)
if [ -n "$src_dir" ]; then
  dir_name=$(basename "$src_dir")
  dest_dir="$HOME/.vscode-oss/extensions/$dir_name"
  if [ ! -d "$dest_dir" ]; then
    echo "Copying paid theme: $dir_name"
    cp -R "$src_dir" "$dest_dir"
  fi
  # Register in extensions.json if not already present
  ext_json="$HOME/.vscode-oss/extensions/extensions.json"
  if [ -f "$ext_json" ] && command -v jq &>/dev/null; then
    if ! jq -e --arg id "{{ . }}" '.[] | select(.identifier.id == $id)' "$ext_json" >/dev/null 2>&1; then
      version="${dir_name#{{ . }}-}"
      echo "Registering $dir_name in extensions.json"
      jq --arg id "{{ . }}" \
         --arg ver "$version" \
         --arg path "$dest_dir" \
         --arg rel "$dir_name" \
         '. + [{
           "identifier": {"id": $id},
           "version": $ver,
           "location": {"$mid": 1, "path": $path, "scheme": "file"},
           "relativeLocation": $rel,
           "metadata": {"installedTimestamp": (now * 1000 | floor), "pinned": true, "source": "vsix"}
         }]' "$ext_json" > "${ext_json}.tmp" && mv "${ext_json}.tmp" "$ext_json"
    fi
  fi
fi
{{ end -}}
{{ end }}
