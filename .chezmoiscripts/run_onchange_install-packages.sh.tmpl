#!/bin/bash

{{ template "utils" . }}

# Newer Homebrew refuses to load formulae/casks from untrusted third-party taps
# when HOMEBREW_REQUIRE_TAP_TRUST is set, which aborts `brew bundle` on our taps
# (turbot, hashicorp, netbird, snyk, speedtest). Disable it so the install runs
# non-interactively. This script is run by bash and does not source zshenv, so it
# must be set here as well as in dot_zshenv.tmpl.
export HOMEBREW_NO_REQUIRE_TAP_TRUST=1

# Add Homebrew to PATH if it exists at known locations
{{ if eq .chezmoi.os "linux" }}
if [ -x "/home/linuxbrew/.linuxbrew/bin/brew" ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi
{{ else if eq .chezmoi.os "darwin" }}
if [ -x "/opt/homebrew/bin/brew" ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi
{{ end }}

if exist brew; then
    info "Running run_onchange_install-packages.sh..."
{{ template "brew" . }}
    if [ $? -eq 0 ]; then
        success "Successfully installed brew packages."
    else
        fail "Some or all brew packages failed to install."
    fi
else
    fail "Command 'brew' not found in PATH. Skipping brew packages."
fi
