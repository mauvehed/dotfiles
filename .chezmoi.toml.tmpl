{{/* boolean feature tags */}}
{{ $ephemeral := false }}{{/* true if this machine is ephemeral, e.g. a cloud or VM instance */}}
{{ $headless := false }}{{/* true if this machine does not have a screen and keyboard */}}
{{ $personal := false }}{{/* true if this machine should have personal secrets */}}
{{ $work := false }}{{/* true if this machine should have work related things and not personal */}}
{{ "" }}

{{ $osID := .chezmoi.os }}
{{ if (and (eq .chezmoi.os "linux") (hasKey .chezmoi.osRelease "id")) }}
{{   $osID = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id }}
{{ end }}

{{/* detect GitHub codespaces, VSCode remote containers, Docker containers, Multipass VMs, and Vagrant boxes */}}
{{ if or (env "CODESPACES") (env "REMOTE_CONTAINERS_IPC") (eq .chezmoi.username "root" "ubuntu" "vagrant" "vscode") }}
{{   $ephemeral = true }}
{{   $headless = true }}
{{ end }}

{{/* work around unreliable hostname on darwin */}}
{{ $hostname := .chezmoi.hostname }}
{{ if eq .chezmoi.os "darwin" }}
{{   $computerName := output "scutil" "--get" "ComputerName" | trim }}
{{   $hostname = $computerName }}
{{ end }}

{{ if eq .chezmoi.os "windows" }}
{{   $ephemeral = true }}
{{ end }}

{{/* classify the machine via cached prompts (promptBoolOnce) instead of a
     hardcoded hostname allowlist, so nothing machine-specific lives in the repo */}}
{{ if not $ephemeral }}
{{   if stdinIsATTY }}
{{     $headless = promptBoolOnce . "headless" "headless" }}
{{     $ephemeral = promptBoolOnce . "ephemeral" "ephemeral" }}
{{     $work = promptBoolOnce . "work" "work" }}
{{     if not $work }}
{{       $personal = promptBoolOnce . "personal" "personal" }}
{{     end }}
{{   else }}
{{     $headless = true }}
{{   end }}
{{ end }}

encryption = "gpg"
[gpg]
    recipient = "19AB 789C 3C87 8FB5 4D37  63D3 4DB4 747D 845D 9ECE"

[data]
    ephemeral = {{ $ephemeral }}
    headless = {{ $headless }}
    hostname = {{ $hostname | quote }}
    personal = {{ $personal }}
    work = {{ $work }}
    osid = {{ $osID | quote }}
    {{/* work machines prompt for the real identity at apply time (cached
         locally, never committed); everything else uses the pseudonym */}}
    {{ if $work }}
    name = {{ promptStringOnce . "name" "name" | quote }}
    email = {{ promptStringOnce . "email" "email" | quote }}
    {{ else }}
    name = "mauvehed"
    email = "mh@mvh.dev"
    {{ end }}
